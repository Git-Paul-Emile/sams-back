# OTP_PROVIDER=dev  -> code affiché en clair (data.devCode) et loggé côté serveur, aucun envoi réel (défaut)
# OTP_PROVIDER=whatsapp -> envoi réel via le provider WhatsApp (WHATSAPP_* requis, compte de production)
OTP_PROVIDER=dev
OTP_TTL_MS=300000
OTP_CODE_LENGTH=6
